# ============================================================
# Second App — example environment
# Copy to .env at the repo root. apps/web + apps/admin + packages/database
# all read from the same file when running via turbo dev.
# ============================================================

# --- Database ---
# Postgres connection string. Prisma reads this from packages/database.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/second_app?schema=public"

# --- Auth ---
# HS256 signing secret for the shared sa_session JWT cookie. Both apps must
# use the same value or admin login cookies won't round-trip.
# Generate with: openssl rand -base64 48
JWT_SECRET="change-me-openssl-rand-base64-48"

# --- OTP / SMS (MSG91) ---
# Leave blank in dev to log OTPs to the server console instead of billing SMS.
# When MSG91_AUTH_KEY is set, sendSms hits MSG91's Flow API and MSG91_TEMPLATE_ID
# must reference a pre-approved template that accepts a {{OTP}} / {{MESSAGE}} var.
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""
MSG91_SENDER_ID="SECAPP"

# Override the generated 6-digit OTP with a fixed value for tests / QA envs.
# Any non-empty value enables the bypass. Leave blank in prod.
DEV_OTP=""

# --- Email (Resend) ---
# Optional — when set, sendEmail routes through Resend instead of the console.
RESEND_API_KEY=""
EMAIL_FROM="Second App <noreply@gosecond.in>"

# --- Payments (Razorpay) ---
# Leave blank to use the mock provider (checkout still works end-to-end,
# orders land in paymentStatus "held" with a mock_ external id).
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# --- Object storage (S3 / Cloudflare R2 / MinIO) ---
# Leave blank in dev to store uploaded photos/videos under apps/web/public/uploads
# (git-ignored). Fill all five for real S3/R2 uploads.
S3_BUCKET=""
S3_REGION="auto"
S3_ENDPOINT="https://<accountid>.r2.cloudflarestorage.com"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Public read URL base — e.g. https://cdn.gosecond.in or the R2 public bucket URL.
S3_PUBLIC_URL=""

# --- Node ---
NODE_ENV="development"
