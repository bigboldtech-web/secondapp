{
  "name": "second-app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "cd packages/database && prisma generate",
    "db:push": "cd packages/database && prisma db push",
    "db:migrate": "cd packages/database && prisma migrate dev",
    "db:migrate:deploy": "cd packages/database && prisma migrate deploy",
    "db:seed": "cd packages/database && tsx seed.ts",
    "db:setup-fts": "cd packages/database && tsx scripts/setup-fts.ts",
    "db:build-search-vocab": "cd packages/database && tsx scripts/build-search-vocab.ts",
    "db:studio": "cd packages/database && prisma studio"
  },
  "devDependencies": {
    "prisma": "^6.0.0",
    "tsx": "^4.0.0",
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
